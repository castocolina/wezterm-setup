#!/bin/bash
# wez-tab — color-code the current WezTerm tab
# Dual-mode: source for shell function + completions, execute to set tab color.

WEZTAB_SELF="${BASH_SOURCE[0]:-$0}"
WEZTAB_SELF="$(cd "$(dirname "$WEZTAB_SELF")" && pwd)/$(basename "$WEZTAB_SELF")"

WEZTAB_COLORS="red orange yellow green teal cyan blue navy purple pink"

_weztab_icon() {
  local name
  name="$(echo "$1" | tr '[:upper:]' '[:lower:]')"
  case "$name" in
    # Languages/Runtimes
    node)     echo "💚" ;;
    python)   echo "🐍" ;;
    rust)     echo "🦀" ;;
    go)       echo "🐹" ;;
    # DevOps/Infra
    docker)   echo "🐳" ;;
    k8s)      echo "☸️" ;;
    server)   echo "🖥️" ;;
    db)       echo "🗄️" ;;
    ssh)      echo "🔐" ;;
    deploy)   echo "🚀" ;;
    monitor)  echo "📊" ;;
    cloud)    echo "☁️" ;;
    network)  echo "🌐" ;;
    # Dev workflow
    git)      echo "🔀" ;;
    build)    echo "🔨" ;;
    test)     echo "🧪" ;;
    debug)    echo "🐛" ;;
    edit)     echo "✏️" ;;
    log)      echo "📋" ;;
    shell)    echo "🐚" ;;
    config)   echo "⚙️" ;;
    search)   echo "🔍" ;;
    clean)    echo "🧹" ;;
    tools)    echo "🔧" ;;
    # Data/Transfer
    api)      echo "📡" ;;
    data)     echo "📦" ;;
    download) echo "⬇️" ;;
    upload)   echo "⬆️" ;;
    sync)     echo "🔄" ;;
    # Concepts
    security) echo "🔒" ;;
    docs)     echo "📝" ;;
    ai)       echo "🧠" ;;
    fire)     echo "🔥" ;;
    alert)    echo "⚠️" ;;
    # Communication/Misc
    mail)     echo "📧" ;;
    chat)     echo "💬" ;;
    home)     echo "🏠" ;;
    music)    echo "🎵" ;;
    game)     echo "🎮" ;;
    *)        return 1 ;;
  esac
}

# --- Section B: Sourced mode ---
_weztab_is_sourced=false
if [ -n "${ZSH_EVAL_CONTEXT:-}" ]; then
  case "$ZSH_EVAL_CONTEXT" in
    *:file:*|*:file) _weztab_is_sourced=true ;;
  esac
elif [ -n "${BASH_SOURCE[0]:-}" ]; then
  if [ "${BASH_SOURCE[0]}" != "$0" ]; then
    _weztab_is_sourced=true
  fi
fi

if [ "$_weztab_is_sourced" = true ]; then
  export WEZTAB_LOADED=1

  wez-tab() {
    command bash "$WEZTAB_SELF" "$@"
  }

  # Bash completions
  if [ -n "${BASH_VERSION:-}" ]; then
    _weztab_completions() {
      local cur="${COMP_WORDS[COMP_CWORD]}"
      local prev="${COMP_WORDS[COMP_CWORD-1]}"
      case "$COMP_CWORD" in
        1)
          COMPREPLY=( $(compgen -W "$WEZTAB_COLORS" -- "$cur") )
          ;;
        2)
          COMPREPLY=( $(compgen -W "node python rust go docker k8s server db ssh deploy monitor cloud network git build test debug edit log shell config search clean tools api data download upload sync security docs ai fire alert mail chat home music game" -- "$cur") )
          ;;
        *)
          COMPREPLY=()
          ;;
      esac
    }
    complete -F _weztab_completions wez-tab
  fi

  # Zsh completions
  if [ -n "${ZSH_VERSION:-}" ]; then
    _weztab_zsh_completions() {
      local -a colors icons
      colors=( ${=WEZTAB_COLORS} )
      icons=( node python rust go docker k8s server db ssh deploy monitor cloud network git build test debug edit log shell config search clean tools api data download upload sync security docs ai fire alert mail chat home music game )
      case "$CURRENT" in
        2)
          _describe 'color' colors
          ;;
        3)
          _describe 'icon' icons
          ;;
        *)
          _message 'title text'
          ;;
      esac
    }
    compdef _weztab_zsh_completions wez-tab
  fi

  unset _weztab_is_sourced
  return 0
fi
unset _weztab_is_sourced

# --- Section C: Executed mode ---
(
set -euo pipefail

_weztab_usage() {
  cat <<'USAGE'
Usage: wez-tab <color> [icon] [title...]

Set the current WezTerm tab's color and optional title/icon.

Colors:
  red   orange   yellow   green   teal
  cyan  blue     navy     purple  pink

Icons (optional second argument):
  Languages:    node 💚    python 🐍   rust 🦀    go 🐹
  DevOps:       docker 🐳  k8s ☸️      server 🖥️  db 🗄️
                ssh 🔐     deploy 🚀   monitor 📊 cloud ☁️
                network 🌐
  Workflow:     git 🔀     build 🔨    test 🧪    debug 🐛
                edit ✏️    log 📋      shell 🐚   config ⚙️
                search 🔍  clean 🧹    tools 🔧
  Data:         api 📡     data 📦     download ⬇️ upload ⬆️
                sync 🔄
  Concepts:     security 🔒 docs 📝    ai 🧠      fire 🔥
                alert ⚠️
  Misc:         mail 📧    chat 💬     home 🏠    music 🎵
                game 🎮

  If the second argument doesn't match an icon name, it's treated as
  part of the title text.

Examples:
  wez-tab blue docker "compose up"   → 🐳 compose up (blue tab)
  wez-tab red "my task"              → my task (red tab, no icon)
  wez-tab green git rebase            → 🔀 rebase (green tab)

Keybindings:
  Alt+|                Split pane right
  Alt+-                Split pane down
  Ctrl+Shift+Arrow     Navigate panes
  Ctrl+Shift+Z         Toggle pane zoom
  Ctrl+Shift+W         Close pane
  Ctrl+Tab / Shift     Next/previous tab
  Alt+Left/Right       Jump between words

  Full list: wezterm show-keys --lua

USAGE

  # Autocomplete warning — WEZTAB_LOADED is exported in sourced mode (Section B)
  if [ -z "${WEZTAB_LOADED:-}" ]; then
    cat <<'WARN'
Note: Autocomplete is not active. To enable tab completion, add this
to your ~/.zshrc or ~/.bashrc:

  [[ -f ~/.local/bin/wez-tab ]] && source ~/.local/bin/wez-tab

WARN
  fi

  cat <<'REFS'
See also:
  wezterm --help        General WezTerm help
  wezterm cli --help    CLI subcommand help
REFS
}

# Handle --help / -h
case "${1:-}" in
  --help|-h|"")
    _weztab_usage
    exit 0
    ;;
esac

color="$1"
shift

# Validate color
_weztab_valid_color=false
for c in $WEZTAB_COLORS; do
  if [ "$c" = "$color" ]; then
    _weztab_valid_color=true
    break
  fi
done
if [ "$_weztab_valid_color" = false ]; then
  echo "Error: Unknown color '$color'" >&2
  echo "Valid colors: $WEZTAB_COLORS" >&2
  exit 1
fi

# Process icon and title
icon=""
title=""
if [ $# -gt 0 ]; then
  candidate="$1"
  if icon_char="$(_weztab_icon "$candidate")"; then
    icon="$icon_char"
    shift
  fi
fi
title="$*"

# Build full title
full_title=""
if [ -n "$icon" ] && [ -n "$title" ]; then
  full_title="$icon $title"
elif [ -n "$icon" ]; then
  full_title="$icon"
elif [ -n "$title" ]; then
  full_title="$title"
fi

# Set color on current tab via OSC 1337 user var
printf '\033]1337;SetUserVar=%s=%s\007' WEZTERM_TAB_COLOR "$(echo -n "$color" | base64)"

# Set per-pane background color via OSC 11 (each pane is its own terminal)
case "$color" in
  red)    _bg_hex='#1f1617' ;;
  orange) _bg_hex='#1f1916' ;;
  yellow) _bg_hex='#1c1c16' ;;
  green)  _bg_hex='#161c17' ;;
  teal)   _bg_hex='#151b1a' ;;
  cyan)   _bg_hex='#161c1c' ;;
  blue)   _bg_hex='#161a1f' ;;
  navy)   _bg_hex='#14151c' ;;
  purple) _bg_hex='#1a161f' ;;
  pink)   _bg_hex='#1f1619' ;;
esac
printf '\033]11;%s\033\\' "$_bg_hex"

# Set title on current tab if provided
if [ -n "$full_title" ]; then
  printf '\033]1337;SetUserVar=%s=%s\007' WEZTERM_TAB_TITLE "$(echo -n "$full_title" | base64)"
fi

# Confirmation
if [ -n "$full_title" ]; then
  echo "Set $color tab: $full_title"
else
  echo "Set $color tab"
fi
)
