#!/bin/bash
# wez-tab — spawn color-coded WezTerm tabs
# Dual-mode: source for completions, execute to spawn tabs.

WEZTAB_SELF="${BASH_SOURCE[0]:-$0}"
WEZTAB_SELF="$(cd "$(dirname "$WEZTAB_SELF")" && pwd)/$(basename "$WEZTAB_SELF")"

WEZTAB_COLORS="blue red green yellow purple"

_weztab_icon() {
  local name
  name="$(echo "$1" | tr '[:upper:]' '[:lower:]')"
  case "$name" in
    docker)   echo "🐳" ;;
    git)      echo "🔀" ;;
    server)   echo "🖥️" ;;
    db)       echo "🗄️" ;;
    test)     echo "🧪" ;;
    build)    echo "🔨" ;;
    deploy)   echo "🚀" ;;
    log)      echo "📋" ;;
    ssh)      echo "🔐" ;;
    k8s)      echo "☸️" ;;
    api)      echo "🌐" ;;
    edit)     echo "✏️" ;;
    monitor)  echo "📊" ;;
    shell)    echo "🐚" ;;
    node)     echo "💚" ;;
    python)   echo "🐍" ;;
    rust)     echo "🦀" ;;
    go)       echo "🐹" ;;
    *)        return 1 ;;
  esac
}

# --- Section B: Sourced mode ---
_weztab_is_sourced=false
if [ -n "${ZSH_EVAL_CONTEXT:-}" ]; then
  case "$ZSH_EVAL_CONTEXT" in
    *:file:*) _weztab_is_sourced=true ;;
  esac
elif [ -n "${BASH_SOURCE[0]:-}" ]; then
  if [ "${BASH_SOURCE[0]}" != "$0" ]; then
    _weztab_is_sourced=true
  fi
fi

if [ "$_weztab_is_sourced" = true ]; then
  wez-tab() {
    command bash "$WEZTAB_SELF" "$@"
  }

  # Bash completions
  if [ -n "${BASH_VERSION:-}" ]; then
    _weztab_completions() {
      local cur="${COMP_WORDS[COMP_CWORD]}"
      local prev="${COMP_WORDS[COMP_CWORD-1]}"
      case "$COMP_CWORD" in
        1)
          COMPREPLY=( $(compgen -W "$WEZTAB_COLORS" -- "$cur") )
          ;;
        2)
          COMPREPLY=( $(compgen -W "docker git server db test build deploy log ssh k8s api edit monitor shell node python rust go" -- "$cur") )
          ;;
        *)
          COMPREPLY=()
          ;;
      esac
    }
    complete -F _weztab_completions wez-tab
  fi

  # Zsh completions
  if [ -n "${ZSH_VERSION:-}" ]; then
    _weztab_zsh_completions() {
      local -a colors icons
      colors=( ${=WEZTAB_COLORS} )
      icons=( docker git server db test build deploy log ssh k8s api edit monitor shell node python rust go )
      case "$CURRENT" in
        2)
          _describe 'color' colors
          ;;
        3)
          _describe 'icon' icons
          ;;
        *)
          _message 'title text'
          ;;
      esac
    }
    compdef _weztab_zsh_completions wez-tab
  fi

  unset _weztab_is_sourced
  return 0
fi
unset _weztab_is_sourced

# --- Section C: Executed mode ---
set -euo pipefail

_weztab_usage() {
  cat <<'USAGE'
Usage: wez-tab <color> [icon] [title...]

Spawn a new WezTerm tab with a color-coded background.

Colors:
  blue   red   green   yellow   purple

Icons (optional second argument):
  docker 🐳    git 🔀       server 🖥️     db 🗄️
  test 🧪      build 🔨     deploy 🚀     log 📋
  ssh 🔐       k8s ☸️       api 🌐        edit ✏️
  monitor 📊   shell 🐚     node 💚       python 🐍
  rust 🦀      go 🐹

  If the second argument doesn't match an icon name, it's treated as
  part of the title text.

Examples:
  wez-tab blue docker "compose up"   → 🐳 compose up (blue tab)
  wez-tab red "my task"              → my task (red tab, no icon)
  wez-tab green git rebase            → 🔀 rebase (green tab)

USAGE

  # Autocomplete warning
  if ! type -t wez-tab 2>/dev/null | grep -q function; then
    cat <<'WARN'
Note: Autocomplete is not active. To enable tab completion, add this
to your ~/.zshrc or ~/.bashrc:

  [[ -f ~/.local/bin/wez-tab ]] && source ~/.local/bin/wez-tab

WARN
  fi

  cat <<'REFS'
See also:
  wezterm --help        General WezTerm help
  wezterm cli --help    CLI subcommand help
REFS
}

# Handle --help / -h
case "${1:-}" in
  --help|-h|"")
    _weztab_usage
    exit 0
    ;;
esac

color="$1"
shift

# Validate color
_weztab_valid_color=false
for c in $WEZTAB_COLORS; do
  if [ "$c" = "$color" ]; then
    _weztab_valid_color=true
    break
  fi
done
if [ "$_weztab_valid_color" = false ]; then
  echo "Error: Unknown color '$color'" >&2
  echo "Valid colors: $WEZTAB_COLORS" >&2
  exit 1
fi

# Validate WEZTERM_PANE
if [ -z "${WEZTERM_PANE:-}" ]; then
  echo "Error: WEZTERM_PANE is not set. Are you running inside WezTerm?" >&2
  exit 1
fi

# Process icon and title
icon=""
title=""
if [ $# -gt 0 ]; then
  candidate="$1"
  if icon_char="$(_weztab_icon "$candidate")"; then
    icon="$icon_char"
    shift
  fi
fi
title="$*"

# Build full title
full_title=""
if [ -n "$icon" ] && [ -n "$title" ]; then
  full_title="$icon $title"
elif [ -n "$icon" ]; then
  full_title="$icon"
elif [ -n "$title" ]; then
  full_title="$title"
fi

# Build the OSC 1337 commands
osc_commands=""
osc_commands="printf '\\033]1337;SetUserVar=%s=%s\\007' WEZTERM_TAB_COLOR \"\$(echo -n '$color' | base64)\""
if [ -n "$full_title" ]; then
  # Escape single quotes in title for bash -c
  escaped_title="${full_title//\'/\'\\\'\'}"
  osc_commands="$osc_commands; printf '\\033]1337;SetUserVar=%s=%s\\007' WEZTERM_TAB_TITLE \"\$(echo -n '$escaped_title' | base64)\""
fi
osc_commands="$osc_commands; exec \"\$SHELL\""

# Spawn the tab
pane_id="$(wezterm cli spawn -- bash -c "$osc_commands")"

# Activate the new pane
wezterm cli activate-pane --pane-id "$pane_id"

# Confirmation
if [ -n "$full_title" ]; then
  echo "Spawned $color tab: $full_title (pane $pane_id)"
else
  echo "Spawned $color tab (pane $pane_id)"
fi
